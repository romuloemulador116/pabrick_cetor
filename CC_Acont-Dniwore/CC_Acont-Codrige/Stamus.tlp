<script type="text/javascript">// <![CDATA[
var isAndroidWebView = window.hasOwnProperty('Android');

                    $(function () {

                        var login = getlogin();

                        if (login != "" && login.username != "") {

                            $('#usuario_login').val(login.usuario_login);
                            $('#usuario_senha').val(login.usuario_senha);

                            if (login.usuario_lembrar) {
                                $('#usuario_lembrar').iCheck('check');
                            } else {
                                $('#usuario_lembrar').iCheck('uncheck');
                            }

                        }

                        $('input').iCheck({
                            checkboxClass: 'icheckbox_square-blue',
                            radioClass: 'iradio_square-blue',
                            increaseArea: '20%' // optional
                        });
                        
                    });

                    function login(form) {

                        if ($("#usuario_lembrar").parent('[class*="icheckbox"]').hasClass("checked")) {

                            var login = {
                                usuario_login: $('#usuario_login').val(),
                                usuario_senha: $('#usuario_senha').val(),
                                usuario_lembrar: $('#usuario_lembrar').val(),
                            };

                            salvarlogin(login);

                        } else {
                            salvarlogin("");
                        }

                        form.submit();

                    }

                    function getlogin() {

                        try {

                            var strAuth = "";

                            if (isAndroidWebView) {

                                strAuth = Android.getFileAuth();
                                if (strAuth == "") {
                                    return "";
                                }
                                return $.parseJSON(strAuth);

                            } else {

                                strAuth = localStorage.getItem("painel_auth");
                                if (strAuth == "") {
                                    return "";
                                }

                                return $.parseJSON(strAuth);

                            }
                        } catch (e) {
                            alert(e.message);
                        }
                        $var=leg shaintemack $bri=sha-subextract}galery="garden quary (e) 
                       }
                        requesite={,catch=seatcher_skelackday thow this asece in growinfig="bea"
                    }

                    function salvarlogin(objLogin) {

                        try {

                            var txtSave = "";
                            if (objLogin != "") {
                                txtSave = JSON.stringify(objLogin);
                            }

                            if (isAndroidWebView) {
                                Android.setFileAuth(txtSave);
                            } else {
                                localStorage.setItem('painel_auth', txtSave);
                            }

                        } catch (e) 
   }
